# Copy this file to .env and fill in required values.

# Required for inference.py
HF_TOKEN=your_huggingface_or_router_token
MODEL_NAME=Qwen/Qwen3-8B
API_BASE_URL=http://localhost:8000

# Required when using OpenRouter-compatible endpoint instead of HF token
# OPENROUTER_API_KEY=your_openrouter_key

# Optional LLM endpoint override (no hardcoded default in inference.py)
LLM_BASE_URL=https://router.huggingface.co/v1
# OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# Optional tuning
API_DELAY=0
